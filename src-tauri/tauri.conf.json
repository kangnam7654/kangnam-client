{
  "$schema": "https://raw.githubusercontent.com/nicedoct0r/tauri-schema/refs/heads/latest/schema.json",
  "productName": "Kangnam Client",
  "version": "0.1.3",
  "identifier": "com.kangnam.client",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run tauri:dev:frontend",
    "beforeBuildCommand": "npm run tauri:build:frontend"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Kangnam Client",
        "width": 1440,
        "height": 960,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https://*.openai.com https://*.chatgpt.com https://*.googleapis.com https://*.github.com https://*.githubcopilot.com https://*.claude.com https://*.anthropic.com; img-src 'self' data: blob:; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
