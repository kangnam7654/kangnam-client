{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./out",
    "composite": true,
    "declaration": true,
    "types": ["node"]
  },
  "include": ["electron/**/*.ts", "electron-vite.config.ts"]
}
